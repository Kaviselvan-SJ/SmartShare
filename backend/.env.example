# ─── Database (Neon PostgreSQL) ──────────────────────────
# Use the full JDBC connection string from Neon dashboard
DB_URL=jdbc:postgresql://<host>.neon.tech/<dbname>?sslmode=require
DB_USERNAME=your-db-username
DB_PASSWORD=your-db-password

# ─── Redis (Upstash) ─────────────────────────────────────
REDIS_HOST=your-upstash-endpoint.upstash.io
REDIS_PORT=6380
REDIS_PASSWORD=your-upstash-password
REDIS_SSL=true

# ─── AWS S3 ──────────────────────────────────────────────
AWS_S3_BUCKET_NAME=your-s3-bucket-name
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_REGION=us-east-1

# ─── Firebase ────────────────────────────────────────────
FIREBASE_PROJECT_ID=your-firebase-project-id
# Paste the full contents of firebase-service-account.json as a single-line JSON string
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# ─── App Config ──────────────────────────────────────────
# URL of your deployed frontend (e.g. Vercel)
FRONTEND_URL=https://your-frontend.vercel.app
ADMIN_EMAILS=admin@yourdomain.com

# ─── Spring ──────────────────────────────────────────────
SPRING_PROFILES_ACTIVE=prod

# ─── Local Development Only ───────────────────────────────
# (These override DB_URL for local PostgreSQL — not needed on Render)
# DB_URL=jdbc:postgresql://localhost:5432/smartshare
# DB_USERNAME=postgres
# DB_PASSWORD=postgres
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=
# REDIS_SSL=false
# FIREBASE_CREDENTIALS_PATH=classpath:firebase-service-account.json
